# Global: normalize all text files to LF on check-in
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Windows batch files use CRLF (to be safe on Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Common config / code files’ LF
*.json text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.env  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf

# Dockerfile(s)
Dockerfile  text eol=lf
Dockerfile* text eol=lf

# Binary files” no line-ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
*.zip  binary
*.tar  binary
*.gz   binary
